---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Hero from '../components/Hero.astro';
import Services from '../components/Services.astro';
import Gallery from '../components/Gallery.astro';
import Contact from '../components/Contact.astro';
import Footer from '../components/Footer.astro';
import Partners from '../components/Partners.astro';
import TechLab from '../components/TechLab.astro';
import Process from '../components/Process.astro';
import Faq from '../components/Faq.astro';
---

<Layout title="SipViba | Publicidad, Impresión de Lona, Vinil y Señalética">
	<Navbar />
	<main>
		<Hero />
		<Partners />
		
		<!-- Vinyl Peel Transition -->
		<div class="relative h-24 w-full overflow-hidden bg-transparent -mt-10 z-20 pointer-events-none">
			<svg viewBox="0 0 1440 320" class="absolute bottom-0 w-full h-full drop-shadow-[0_-10px_15px_rgba(0,0,0,0.5)]" preserveAspectRatio="none">
				<path fill="#0B0F19" fill-opacity="1" d="M0,256L48,229.3C96,203,192,149,288,154.7C384,160,480,224,576,218.7C672,213,768,139,864,128C960,117,1056,171,1152,197.3C1248,224,1344,224,1392,224L1440,224L1440,320L1392,320C1344,320,1248,320,1152,320C1056,320,960,320,864,320C768,320,672,320,576,320C480,320,384,320,288,320C192,320,96,320,48,320L0,320Z"></path>
			</svg>
		</div>

    <!-- Global Print Zone (Services + TechLab + Gallery + Process) -->
    <div id="unified-print-zone" class="relative bg-brand-dark">
      <!-- Unprinted Base Canvas -->
      <div class="absolute inset-0 z-0 pointer-events-none">
        <div class="absolute inset-0 opacity-[0.03] bg-[url('data:image/svg+xml;base64,')]"></div>
      </div>
      
      <!-- The Single Global Neon Laser -->
      <div id="global-print-head" class="absolute left-0 w-full z-30 opacity-0 transition-all duration-75 ease-out flex items-center justify-center pointer-events-none" style="top: 0%; height: 6px;">
        <div class="w-full h-full bg-white rounded-full relative">
          <div class="absolute inset-0 bg-gradient-to-r from-brand-cyan to-brand-magenta blur-[8px] opacity-100 rounded-full"></div>
          <div class="absolute inset-0 bg-gradient-to-r from-brand-cyan to-brand-magenta blur-[20px] opacity-70 rounded-full"></div>
          <div class="absolute inset-0 bg-gradient-to-r from-brand-cyan to-brand-magenta blur-[40px] opacity-50 rounded-full"></div>
        </div>
      </div>

      <!-- The Revealed Layer (Background + Content are printed together) -->
      <div id="global-revealed-layer" class="relative z-10 transition-all duration-75 ease-out" style="clip-path: inset(0 0 100% 0);">
        <!-- Vibrant Printed Background with Noise -->
        <div class="absolute inset-0 z-0 pointer-events-none overflow-hidden">
          <div class="absolute inset-0 bg-gradient-to-br from-brand-cyan/30 via-[#100520] to-brand-magenta/10"></div>
          
          <!-- Soft Aurora Lights (Clean & Smooth) -->
          <div class="absolute inset-0 opacity-30">
            <div class="absolute top-[-20%] left-[10%] w-[70vw] h-[70vw] bg-gradient-to-br from-brand-cyan/10 to-transparent rounded-full blur-[100px] pointer-events-none"></div>
            <div class="absolute bottom-[-20%] right-[10%] w-[70vw] h-[70vw] bg-gradient-to-tl from-brand-magenta/5 to-transparent rounded-full blur-[100px] pointer-events-none"></div>
          </div>
          
          <!-- CMYK Grid -->
          <div class="absolute top-0 left-0 w-full h-full opacity-40 mix-blend-screen bg-[url('data:image/svg+xml;base64,')]"></div>
          
          <!-- Plasma Orbs -->
          <div class="absolute top-[10%] left-[-10%] w-[50vw] h-[50vw] bg-brand-cyan/20 rounded-full blur-[150px] mix-blend-screen animate-plasma-slow"></div>
          <div class="absolute bottom-[10%] right-[-10%] w-[50vw] h-[50vw] bg-brand-magenta/10 rounded-full blur-[150px] mix-blend-screen animate-plasma-delayed"></div>

          <!-- Giant Animated Marquee Background -->
          <div class="absolute top-1/4 left-0 w-[200%] -rotate-6 opacity-[0.03] select-none flex overflow-hidden">
            <div class="animate-marquee whitespace-nowrap flex items-center">
              <span class="text-[18vw] font-black uppercase text-white tracking-tighter mx-8">IMPRESIÓN</span>
              <span class="text-[18vw] font-black uppercase text-transparent stroke-text tracking-tighter mx-8">DISEÑO</span>
              <span class="text-[18vw] font-black uppercase text-white tracking-tighter mx-8">ROTULACIÓN</span>
              <span class="text-[18vw] font-black uppercase text-transparent stroke-text tracking-tighter mx-8">GRAN FORMATO</span>
            </div>
            <div class="animate-marquee whitespace-nowrap flex items-center">
              <span class="text-[18vw] font-black uppercase text-white tracking-tighter mx-8">IMPRESIÓN</span>
              <span class="text-[18vw] font-black uppercase text-transparent stroke-text tracking-tighter mx-8">DISEÑO</span>
              <span class="text-[18vw] font-black uppercase text-white tracking-tighter mx-8">ROTULACIÓN</span>
              <span class="text-[18vw] font-black uppercase text-transparent stroke-text tracking-tighter mx-8">GRAN FORMATO</span>
            </div>
          </div>
        </div>

        <!-- The actual Content -->
        <div class="relative z-10">
          <Services />
          <TechLab />
          <Gallery />
          <Process />
        </div>
      </div>
    </div>

		<Contact />
		<Faq />
	</main>

  <script>
    // Unified Print Zone Logic
    document.addEventListener("DOMContentLoaded", () => {
      const section = document.getElementById('unified-print-zone');
      const revealedBg = document.getElementById('global-revealed-layer');
      const printHead = document.getElementById('global-print-head');
      
      if (!section || !revealedBg || !printHead) return;

      let rafId = null;
      let isScrubbing = false;

      const updateReveal = () => {
        const rect = section.getBoundingClientRect();
        const windowHeight = window.innerHeight;
        
        const topOffset = rect.top;
        
        // El láser se mantendrá estático en la pantalla al 85% de la altura (windowHeight * 0.85)
        // Esto le da mucho "adelanto" para que el usuario pueda leer el centro de la pantalla perfectamente.
        const startTrigger = windowHeight * 0.85;
        const endTrigger = startTrigger - rect.height;
        
        let progress = (startTrigger - topOffset) / (startTrigger - endTrigger);
        progress = Math.max(0, Math.min(1, progress));

        const insetBottom = 100 - (progress * 100);
        revealedBg.style.clipPath = `inset(0 0 ${insetBottom}% 0)`;
        
        printHead.style.top = `${progress * 100}%`;
        
        if (progress > 0 && progress < 1) {
          printHead.style.opacity = '1';
        } else {
          printHead.style.opacity = '0';
        }

        isScrubbing = false;
      };

      window.addEventListener('scroll', () => {
        if (!isScrubbing) {
          isScrubbing = true;
          rafId = requestAnimationFrame(updateReveal);
        }
      }, { passive: true });
      
      updateReveal();
    });
  </script>
	<Footer />

  <style is:global>
    .stroke-text {
      -webkit-text-stroke: 2px rgba(255, 255, 255, 0.8);
      color: transparent;
    }

    @keyframes marquee {
      0% { transform: translateX(0%); }
      100% { transform: translateX(-100%); }
    }

    .animate-marquee {
      animation: marquee 30s linear infinite;
    }
  </style>
</Layout>
