---
const steps = [
  {
    num: "01",
    title: "Visión & Diseño",
    desc: "Análisis meticuloso de tu proyecto. Adaptamos tus ideas a los formatos exactos, asegurando perfiles de color perfectos y resoluciones impecables antes de imprimir.",
    color: "brand-cyan"
  },
  {
    num: "02",
    title: "Producción Técnica",
    desc: "Nuestros equipos de inyección y corte de precisión entran en acción. Materiales premium y calibración exacta para garantizar colores vibrantes y acabados duraderos.",
    color: "brand-magenta"
  },
  {
    num: "03",
    title: "Instalación y Entrega",
    desc: "El toque final. Nuestro equipo especializado realiza el montaje físico con absoluta precisión, asegurando que tu marca brille exactamente donde debe estar.",
    color: "brand-cyan"
  }
];
---
<section id="proceso" class="py-32 relative overflow-hidden bg-transparent">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    
    <div class="text-center mb-24 relative">
      <h2 class="text-xs font-black text-white/50 tracking-[0.4em] uppercase mb-4 flex justify-center items-center gap-3">
        <span class="w-1.5 h-1.5 bg-brand-cyan rounded-full animate-pulse shadow-[0_0_8px_#00E5FF]"></span> 
        Nuestra Metodología
      </h2>
      <h3 class="text-4xl md:text-6xl font-black text-transparent bg-clip-text bg-gradient-to-r from-white via-white/90 to-white/60 uppercase tracking-tight drop-shadow-xl">
        El Arte de Producir
      </h3>
    </div>

    <!-- Glassmorphic Process Cards & Animated Timeline -->
    <div class="relative">
      
      <!-- Horizontal Connecting Animated Line (Desktop) -->
      <div class="hidden md:block absolute top-[50%] left-0 w-full h-[2px] bg-white/5 z-0 -translate-y-1/2">
        <div class="h-full bg-brand-cyan w-1/3 animate-[flowLine_4s_ease-in-out_infinite_alternate] shadow-[0_0_15px_var(--color-brand-cyan)] rounded-full"></div>
      </div>

      <!-- Vertical Connecting Animated Line (Mobile) -->
      <div class="md:hidden absolute left-[50%] top-0 w-[2px] h-full bg-white/5 z-0 -translate-x-1/2">
         <div class="w-full bg-brand-cyan h-1/3 animate-[flowLineVertical_4s_ease-in-out_infinite_alternate] shadow-[0_0_15px_var(--color-brand-cyan)] rounded-full"></div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 relative z-10">
        {steps.map((step, index) => (
          <div class="group relative h-full pt-8 md:pt-0">
            <!-- Background Glow on Hover -->
            <div class={`absolute inset-0 bg-${step.color}/20 rounded-3xl blur-3xl opacity-0 group-hover:opacity-100 transition-opacity duration-700 pointer-events-none`}></div>
            
            <!-- Timeline Node (Intersection point) -->
            <div class="absolute top-0 left-1/2 md:top-1/2 md:-left-4 -translate-x-1/2 md:translate-x-0 -translate-y-1/2 w-4 h-4 rounded-full bg-brand-dark border-2 border-white/20 z-20 group-hover:border-brand-cyan group-hover:bg-brand-cyan group-hover:shadow-[0_0_15px_var(--color-brand-cyan)] transition-all duration-300"></div>

            <!-- The Glass Card -->
            <div class="relative h-full p-10 md:p-12 rounded-3xl bg-white/5 backdrop-blur-2xl border border-white/10 hover:border-white/20 hover:bg-white/10 transition-all duration-500 overflow-hidden flex flex-col shadow-[0_15px_40px_rgba(0,0,0,0.4)] mt-4 md:mt-0">
              
              <!-- Massive Background Number -->
              <div class="absolute -top-6 -right-6 text-[10rem] font-black text-white/[0.03] group-hover:text-white/[0.06] transition-colors duration-500 pointer-events-none select-none leading-none">
                {step.num}
              </div>

              <!-- Content -->
              <div class="relative z-10 flex-grow flex flex-col">
                <div class="flex items-center gap-4 mb-8">
                  <div class={`w-12 h-12 rounded-full border border-${step.color}/30 bg-${step.color}/10 flex items-center justify-center group-hover:border-${step.color} group-hover:shadow-[0_0_20px_var(--color-${step.color})] transition-all duration-500`}>
                    <span class={`text-${step.color} font-mono font-bold text-lg`}>{step.num}</span>
                  </div>
                  <h4 class="text-xl md:text-2xl font-bold text-white uppercase tracking-wider">{step.title}</h4>
                </div>
                
                <p class="text-white/60 text-lg leading-relaxed group-hover:text-white/90 transition-colors duration-300 font-light mt-auto">
                  {step.desc}
                </p>
              </div>
              
              <!-- Bottom decorative line -->
              <div class={`absolute bottom-0 left-0 w-0 h-1 bg-${step.color} group-hover:w-full transition-all duration-700 ease-out`}></div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  @keyframes flowLine {
    0% { transform: translateX(0%); width: 0%; }
    50% { width: 100%; transform: translateX(0%); }
    100% { width: 0%; transform: translateX(300%); }
  }
  @keyframes flowLineVertical {
    0% { transform: translateY(0%); height: 0%; }
    50% { height: 100%; transform: translateY(0%); }
    100% { height: 0%; transform: translateY(300%); }
  }
</style>
