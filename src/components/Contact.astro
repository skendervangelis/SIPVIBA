---
---
<section id="contacto" class="py-32 relative overflow-hidden bg-transparent min-h-screen flex items-center">
  <!-- Clean Ambient Background Glow -->
  <div class="absolute inset-0 z-0 pointer-events-none opacity-40 overflow-hidden">
    <div class="absolute top-1/4 left-[10%] w-[40vw] h-[40vw] bg-brand-cyan/20 rounded-full blur-[120px] mix-blend-screen animate-plasma-slow"></div>
    <div class="absolute bottom-1/4 right-[10%] w-[40vw] h-[40vw] bg-brand-magenta/20 rounded-full blur-[120px] mix-blend-screen animate-plasma-delayed"></div>
  </div>

  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10 w-full">
    
    <!-- Contact Header -->
    <div class="text-center mb-16 relative">
      <div class="inline-block px-6">
        <h2 class="text-xs font-black text-white/50 tracking-[0.4em] uppercase mb-6 flex justify-center items-center gap-4">
          <span class="w-1.5 h-1.5 bg-brand-cyan rounded-full animate-pulse shadow-[0_0_8px_#00E5FF]"></span> 
          Iniciar Producción
          <span class="w-1.5 h-1.5 bg-brand-magenta rounded-full animate-pulse shadow-[0_0_8px_#FF00FF]"></span>
        </h2>
        <h3 class="text-5xl md:text-7xl font-black mb-6 text-transparent bg-clip-text bg-gradient-to-r from-white via-white/90 to-white/60 tracking-tight drop-shadow-2xl">
          Cotiza tu Proyecto
        </h3>
      </div>
    </div>

    <!-- Contact Form Container - Ultra Premium Glass Console -->
    <div class="relative rounded-[2.5rem] p-8 md:p-14 border border-white/10 bg-gradient-to-b from-white/10 to-white/5 backdrop-blur-3xl shadow-[0_30px_80px_rgba(0,0,0,0.6)] overflow-hidden group/console">
      
      <!-- Top edge highlight -->
      <div class="absolute top-0 left-0 w-full h-[1px] bg-gradient-to-r from-transparent via-white/30 to-transparent"></div>

      <!-- The Form -->
      <form class="space-y-10 relative z-10" id="contact-form">
        
        <div class="grid grid-cols-1 md:grid-cols-2 gap-10">
          
          <!-- Nombre Input -->
          <div class="relative group">
            <div class="absolute -inset-1 bg-gradient-to-r from-brand-cyan to-brand-cyan/0 rounded-2xl blur opacity-0 group-focus-within:opacity-20 transition duration-500"></div>
            <div class="relative bg-black/40 border border-white/10 rounded-2xl p-2 transition-all duration-300 group-focus-within:border-brand-cyan/50 group-focus-within:bg-black/60">
              <label for="name" class="block text-white/40 mb-1 px-4 pt-2 uppercase tracking-[0.2em] text-[10px] font-bold transition-colors group-focus-within:text-brand-cyan">Nombre / Empresa</label>
              <input type="text" id="name" class="w-full bg-transparent border-none text-white text-lg px-4 pb-2 focus:outline-none focus:ring-0 placeholder:text-white/20 font-light" placeholder="¿Cómo te llamamos?" />
            </div>
          </div>
          
          <!-- Teléfono Input -->
          <div class="relative group">
            <div class="absolute -inset-1 bg-gradient-to-r from-brand-magenta to-brand-magenta/0 rounded-2xl blur opacity-0 group-focus-within:opacity-20 transition duration-500"></div>
            <div class="relative bg-black/40 border border-white/10 rounded-2xl p-2 transition-all duration-300 group-focus-within:border-brand-magenta/50 group-focus-within:bg-black/60">
              <label for="phone" class="block text-white/40 mb-1 px-4 pt-2 uppercase tracking-[0.2em] text-[10px] font-bold transition-colors group-focus-within:text-brand-magenta">Teléfono de Contacto</label>
              <input type="tel" id="phone" class="w-full bg-transparent border-none text-white text-lg px-4 pb-2 focus:outline-none focus:ring-0 placeholder:text-white/20 font-light" placeholder="A 10 dígitos" />
            </div>
          </div>
        </div>
        
        <!-- Select Input -->
        <div class="relative group">
          <div class="absolute -inset-1 bg-gradient-to-r from-[#00ff88] to-[#00ff88]/0 rounded-2xl blur opacity-0 group-focus-within:opacity-20 transition duration-500"></div>
          <div class="relative bg-black/40 border border-white/10 rounded-2xl p-2 transition-all duration-300 group-focus-within:border-[#00ff88]/50 group-focus-within:bg-black/60">
            <label for="service" class="block text-white/40 mb-1 px-4 pt-2 uppercase tracking-[0.2em] text-[10px] font-bold transition-colors group-focus-within:text-[#00ff88]">Requerimiento Principal</label>
            <select id="service" class="w-full bg-transparent border-none text-white text-lg px-4 pb-2 focus:outline-none focus:ring-0 appearance-none cursor-pointer font-light">
              <option value="" class="bg-brand-dark text-white/50">Selecciona el tipo de trabajo...</option>
              <option value="lona" class="bg-brand-dark">Impresión de Lona / Gran Formato</option>
              <option value="vinil" class="bg-brand-dark">Forrado y Rotulación Automotriz</option>
              <option value="letrero" class="bg-brand-dark">Letreros Neón y Acrílico 3D</option>
              <option value="sublimacion" class="bg-brand-dark">Sublimación y Textil Premium</option>
              <option value="otro" class="bg-brand-dark">Otro (Detallar abajo)</option>
            </select>
            <!-- Custom Arrow -->
            <div class="absolute right-6 top-1/2 -translate-y-1/2 pointer-events-none text-white/40 group-focus-within:text-[#00ff88] transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
            </div>
          </div>
        </div>

        <!-- Textarea Input -->
        <div class="relative group">
          <div class="absolute -inset-1 bg-gradient-to-r from-white to-transparent rounded-2xl blur opacity-0 group-focus-within:opacity-10 transition duration-500"></div>
          <div class="relative bg-black/40 border border-white/10 rounded-2xl p-2 transition-all duration-300 group-focus-within:border-white/30 group-focus-within:bg-black/60">
            <label for="message" class="block text-white/40 mb-1 px-4 pt-2 uppercase tracking-[0.2em] text-[10px] font-bold transition-colors group-focus-within:text-white">Especificaciones (Medidas, Colores, Detalles)</label>
            <textarea id="message" rows="4" class="w-full bg-transparent border-none text-white text-lg px-4 pb-2 pt-2 focus:outline-none focus:ring-0 resize-none placeholder:text-white/20 font-light leading-relaxed" placeholder="Danos los detalles para darte la cotización exacta..."></textarea>
          </div>
        </div>

        <!-- Submit Button -->
        <div class="pt-6">
          <button type="submit" class="w-full py-6 rounded-2xl border border-white/20 text-white bg-gradient-to-r from-white/5 to-transparent hover:border-white/50 font-black tracking-[0.2em] uppercase transition-all duration-500 relative overflow-hidden group/btn shadow-[0_10px_30px_rgba(0,0,0,0.3)] hover:shadow-[0_0_40px_rgba(255,255,255,0.1)]">
            
            <!-- Holographic sweep -->
            <div class="absolute inset-0 bg-gradient-to-r from-transparent via-brand-cyan/30 to-brand-magenta/30 -translate-x-full group-hover/btn:animate-[sweep_1.5s_ease-in-out_infinite] opacity-50"></div>
            
            <span class="relative z-10 flex justify-center items-center gap-4">
              <span>Enviar a Taller de Producción</span>
              <svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="relative z-10 transition-transform duration-500 group-hover/btn:translate-x-3 text-brand-cyan"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
            </span>
          </button>
        </div>
      </form>
    </div>
  </div>
</section>

<style is:global>
  textarea::-webkit-scrollbar { width: 6px; }
  textarea::-webkit-scrollbar-track { background: transparent; }
  textarea::-webkit-scrollbar-thumb { background: rgba(255, 255, 255, 0.1); border-radius: 10px; }
  textarea::-webkit-scrollbar-thumb:hover { background: rgba(255, 255, 255, 0.3); }

  @keyframes sweep {
    0% { transform: translateX(-100%); }
    100% { transform: translateX(100%); }
  }
</style>
