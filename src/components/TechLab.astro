---
const specs = [
  {
    title: "Resolución 4K en Gran Formato",
    desc: "Cabezales de impresión Micro Piezo con tecnología de gota variable. Nitidez fotográfica absoluta para lonas y espectaculares.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="4 7 4 4 20 4 20 7"/><line x1="9" y1="20" x2="15" y2="20"/><line x1="12" y1="4" x2="12" y2="20"/></svg>`,
    color: "from-brand-cyan to-blue-500",
    glow: "bg-brand-cyan"
  },
  {
    title: "Tintas Eco-Solventes Premium",
    desc: "Sustratos y tintas ecológicas de ultra resistencia UV. Garantía extendida al exterior sin pérdida de saturación ni brillo.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2.69l5.66 5.66a8 8 0 1 1-11.31 0z"/></svg>`,
    color: "from-brand-magenta to-pink-500",
    glow: "bg-brand-magenta"
  },
  {
    title: "Plotters de Recorte Automatizados",
    desc: "Precisión milimétrica para corte de vinil automotriz, textil y arquitectónico. Detalles perfectos en cada curvatura.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="6" cy="6" r="3"/><circle cx="6" cy="18" r="3"/><line x1="20" y1="4" x2="8.12" y2="15.88"/><line x1="14.47" y1="14.48" x2="20" y2="20"/><line x1="8.12" y1="8.12" x2="12" y2="12"/></svg>`,
    color: "from-[#ffdd00] to-orange-500",
    glow: "bg-[#ffdd00]"
  }
];
---
<section class="py-32 relative overflow-hidden bg-transparent perspective-1000">
  
  <!-- Animated Background Printing Effect -->
  <div class="absolute inset-0 z-0 pointer-events-none opacity-20 overflow-hidden">
    <!-- Grid Base -->
    <div class="absolute inset-0 bg-[linear-gradient(rgba(255,255,255,0.05)_1px,transparent_1px),linear-gradient(90deg,rgba(255,255,255,0.05)_1px,transparent_1px)] bg-[length:40px_40px] [transform:rotateX(60deg)_translateZ(-100px)_scale(2)] transform-origin-bottom"></div>
    
    <!-- Moving Print Head / Plotter Scanner -->
    <div class="absolute top-0 left-0 w-full h-[3px] bg-brand-cyan shadow-[0_0_30px_#00E5FF] animate-scan-vertical opacity-50 mix-blend-screen z-10"></div>
  </div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    
    <div class="mb-20 flex flex-col items-center text-center">
      <div class="inline-flex items-center gap-4 mb-4 px-6 py-2 bg-white/5 border border-white/10 rounded-full backdrop-blur-md shadow-lg">
        <span class="w-3 h-3 rounded-full bg-brand-magenta animate-pulse shadow-[0_0_10px_#FF00FF]"></span>
        <h2 class="text-xs font-black text-white/80 tracking-[0.3em] uppercase">
          Ecosistema de Producción
        </h2>
        <span class="w-3 h-3 rounded-full bg-brand-cyan animate-pulse shadow-[0_0_10px_#00E5FF]"></span>
      </div>
      <h3 class="text-5xl md:text-7xl font-black text-transparent bg-clip-text bg-gradient-to-r from-white via-white/90 to-white/50 tracking-tight drop-shadow-2xl">
        Tecnología de Punta
      </h3>
    </div>

    <!-- Floating Glass Screens -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 md:gap-12 lg:gap-16 relative">
      <!-- Horizontal Connecting Line Behind Cards -->
      <div class="hidden md:block absolute top-1/2 left-0 w-full h-[2px] bg-gradient-to-r from-brand-cyan/0 via-brand-cyan/50 to-brand-magenta/0 -z-10 -translate-y-1/2"></div>

      {specs.map((spec, i) => (
        <div class="group relative z-10" style={`animation: float ${6 + i}s ease-in-out infinite;`}>
          <!-- Floating Connection Nodes -->
          <div class={`hidden md:block absolute top-1/2 -left-6 w-4 h-4 rounded-full border-2 border-white/20 bg-brand-dark z-0 -translate-y-1/2 group-hover:border-white/50 transition-colors`}></div>
          <div class={`hidden md:block absolute top-1/2 -right-6 w-4 h-4 rounded-full border-2 border-white/20 bg-brand-dark z-0 -translate-y-1/2 group-hover:border-white/50 transition-colors`}></div>

          <div class="relative p-[1px] rounded-[2.5rem] bg-gradient-to-b from-white/20 via-white/5 to-transparent overflow-hidden transition-all duration-700 hover:-translate-y-4 hover:scale-[1.03] shadow-2xl hover:shadow-[0_30px_60px_rgba(0,0,0,0.6)] backdrop-blur-2xl">
            <!-- Glassmorphic Screen Layer -->
            <div class="relative h-full p-8 md:p-10 bg-gradient-to-b from-white/10 to-white/5 rounded-[2.5rem] flex flex-col items-start z-10 border border-white/10 group-hover:border-white/30 transition-colors duration-500">
              
              <!-- Scanning reflection inside glass -->
              <div class="absolute top-0 left-[-100%] w-1/2 h-full bg-gradient-to-r from-transparent via-white/10 to-transparent skew-x-[-25deg] group-hover:animate-glass-reflection"></div>
              
              <!-- Data / Model Number Top Right -->
              <div class="absolute top-8 right-8 font-mono text-[10px] text-white/30 tracking-widest uppercase">
                MOD_{i + 1}00X
              </div>

              <!-- Animated Icon Container -->
              <div class="relative mb-10 w-20 h-20">
                <div class={`absolute inset-0 ${spec.glow} opacity-20 blur-xl group-hover:opacity-60 group-hover:blur-2xl transition-all duration-500 rounded-full`}></div>
                <div class="absolute inset-0 bg-white/10 rounded-2xl border border-white/20 flex items-center justify-center text-white backdrop-blur-md z-10 group-hover:bg-white/20 transition-colors duration-500">
                  <div class="relative z-10 group-hover:scale-110 transition-transform duration-500 drop-shadow-md" set:html={spec.icon} />
                </div>
              </div>
              
              <h4 class="text-2xl lg:text-3xl font-black text-white mb-4 drop-shadow-lg tracking-tight leading-tight group-hover:text-transparent group-hover:bg-clip-text group-hover:bg-gradient-to-r group-hover:from-white group-hover:to-white/70 transition-all duration-300">
                {spec.title}
              </h4>
              <div class="w-12 h-1 bg-white/20 rounded-full mb-6 group-hover:w-full transition-all duration-700 ease-out">
                <div class={`h-full ${spec.glow} rounded-full w-0 group-hover:w-full transition-all duration-700 ease-out delay-100 opacity-50`}></div>
              </div>
              
              <p class="text-white/70 leading-relaxed text-lg group-hover:text-white/90 transition-colors duration-300 font-light">
                {spec.desc}
              </p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .perspective-1000 {
    perspective: 1000px;
  }
  
  @keyframes float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-15px); }
  }

  @keyframes scan-vertical {
    0% { transform: translateY(-100%); }
    100% { transform: translateY(100vh); }
  }

  .animate-scan-vertical {
    animation: scan-vertical 4s linear infinite;
  }

  @keyframes glass-reflection {
    0% { left: -100%; }
    100% { left: 200%; }
  }

  .animate-glass-reflection {
    animation: glass-reflection 1.5s ease-out forwards;
  }
</style>
